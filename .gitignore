# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Python (in case we add Python tooling later)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Node (in case we add a web capture tool)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ML artifacts — never commit large weights or raw data by accident
*.h5
*.pt
*.pth
*.ckpt
*.tflite
*.onnx
*.pb
*.bin
*.safetensors
*.npy
*.npz

# Dataset caches — explicit opt-in only
data/raw/
data/cache/
data/*.zip
data/*.tar
data/*.tar.gz
models/checkpoints/

# Misc
.env
.env.local
*.log
